	margin-top: 16rpx;
	transition: transform 0.15s ease, opacity 0.15s ease;
	&:active { transform: scale(0.97); opacity: 0.85; }
}

.ticket-list {
	margin-bottom: 16rpx;
}

.ticket-item {
