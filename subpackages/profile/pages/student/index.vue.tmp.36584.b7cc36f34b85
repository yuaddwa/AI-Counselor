	display: flex;
	align-items: center;
	padding: 28rpx 24rpx;
	border-bottom: 1rpx solid #F5F5F5;
	transition: background 0.15s ease;
	&:last-child { border-bottom: none; }
	&:active { background: #F8F8F8; }
}

.menu-icon {
	font-size: 36rpx;
	width: 48rpx;
	text-align: center;
	margin-right: 16rpx;
}

