}

@keyframes avatarPop {
	0% { opacity: 0; transform: scale(0.5); }
	60% { transform: scale(1.1); }
	100% { opacity: 1; transform: scale(1); }
}

@keyframes fadeSlideUp {
	from { opacity: 0; transform: translateY(30rpx); }
	to { opacity: 1; transform: translateY(0); }
}

@keyframes fadeIn {
	from { opacity: 0; }
	to { opacity: 1; }
}

