	margin: 24rpx 24rpx 0;
	background: #FFF;
	border-radius: 16rpx;
	overflow: hidden;
	animation: fadeSlideUp 0.4s ease both;
	&:nth-child(1) { animation-delay: 0.1s; }
	&:nth-child(2) { animation-delay: 0.2s; }
}

