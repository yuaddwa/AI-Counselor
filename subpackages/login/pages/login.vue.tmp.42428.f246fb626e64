		font-size: 32rpx;
	}
	&.active {
		color: #3A7CC5;
		font-weight: 600;
	}
}

.login-form {
	display: flex;
	flex-direction: column;
	animation: fadeSlideUp 0.35s ease both;
}

.input-group {
	display: flex;
	align-items: center;
	height: 100rpx;
	background: #F7FAFE;
	border-radius: 16rpx;
	padding: 0 24rpx;
	margin-bottom: 24rpx;
	border: 2rpx solid #EDF2F7;
	animation: fadeSlideUp 0.4s ease both;
	&:nth-child(1) { animation-delay: 0.05s; }
	&:nth-child(2) { animation-delay: 0.1s; }
	transition: border-color 0.3s ease, box-shadow 0.3s ease, background 0.3s ease;
	&.focused {
		border-color: rgba(91,155,213,0.4);
		box-shadow: 0 0 0 4rpx rgba(91,155,213,0.08);
		background: #FFF;
	}
}

.input-icon {
	font-size: 34rpx;
	margin-right: 18rpx;
	width: 48rpx;
	text-align: center;
}

.login-input {
	flex: 1;
	height: 100%;
	font-size: 28rpx;
	color: #333;
}

.input-eye {
	width: 56rpx;
	height: 100%;
	display: flex;
	align-items: center;
	justify-content: center;
	font-size: 34rpx;
	transition: transform 0.2s ease;
	&:active { transform: scale(1.2); }
}

.login-btn {
	height: 96rpx;
	background: linear-gradient(135deg, #4A90D9 0%, #6BA8E4 50%, #7BB8E8 100%);
	border-radius: 16rpx;
	display: flex;
	align-items: center;
	justify-content: center;
	font-size: 34rpx;
	color: #FFF;
	font-weight: 600;
	margin-top: 16rpx;
	letter-spacing: 8rpx;
	animation: fadeSlideUp 0.4s ease 0.15s both;
	transition: transform 0.15s ease, box-shadow 0.3s ease;
	box-shadow: 0 8rpx 24rpx rgba(74,144,217,0.35);
	&:active {
		transform: scale(0.97);
		box-shadow: 0 4rpx 12rpx rgba(74,144,217,0.25);
	}
	&.loading {
		opacity: 0.85;
	}
}

.btn-loading {
	display: flex;
	align-items: center;
	gap: 12rpx;
}

.spinner {
	width: 32rpx;
	height: 32rpx;
	border: 3rpx solid rgba(255,255,255,0.3);
	border-top-color: #FFF;
	border-radius: 50%;
	animation: spin 0.8s linear infinite;
}

.forgot-link {
	text-align: center;
	margin-top: 28rpx;
	font-size: 26rpx;
	color: rgba(91,155,213,0.6);
	animation: fadeIn 0.4s ease 0.25s both;
	transition: color 0.2s ease;
	&:active { color: #3A7CC5; }
}

.card-footer {
	text-align: center;
	margin-top: 36rpx;
	font-size: 22rpx;
	color: #CCC;
	animation: fadeIn 0.4s ease 0.35s both;
	.link {
		color: rgba(91,155,213,0.5);
		&:active { color: #3A7CC5; }
	}
}

.bottom-deco {
	text-align: center;
	padding: 48rpx 0 32rpx;
	animation: fadeIn 0.6s ease 0.5s both;
}

.deco-text {
	font-size: 22rpx;
	color: rgba(91,155,213,0.2);
	letter-spacing: 4rpx;
	text-transform: uppercase;
}

.error-toast {
	position: fixed;
	top: 50%;
	left: 50%;
	transform: translate(-50%, -50%);
	background: rgba(0,0,0,0.8);
	color: #FFF;
	padding: 24rpx 48rpx;
	border-radius: 16rpx;
	font-size: 28rpx;
	z-index: 9999;
	animation: errorPop 0.3s ease both;
}

@keyframes fadeSlideDown {
	from { opacity: 0; transform: translateY(-30rpx); }
	to { opacity: 1; transform: translateY(0); }
}

@keyframes fadeSlideUp {
	from { opacity: 0; transform: translateY(40rpx); }
	to { opacity: 1; transform: translateY(0); }
}

@keyframes cardSlideUp {
	0% { opacity: 0; transform: translateY(60rpx) scale(0.95); }
	60% { transform: translateY(-6rpx) scale(1.01); }
	100% { opacity: 1; transform: translateY(0) scale(1); }
}

@keyframes fadeIn {
	from { opacity: 0; }
	to { opacity: 1; }
}

@keyframes logoPop {
	0% { opacity: 0; transform: scale(0.3) rotate(-15deg); }
	50% { transform: scale(1.15) rotate(5deg); }
	70% { transform: scale(0.95) rotate(-2deg); }
	100% { opacity: 1; transform: scale(1) rotate(0deg); }
}

@keyframes logoFloat {
	0%, 100% { transform: translateY(0); }
	50% { transform: translateY(-8rpx); }
}

@keyframes ringRotate {
	from { transform: rotate(0deg); }
	to { transform: rotate(360deg); }
}

@keyframes floatBubble {
	0%, 100% { transform: translateY(0) scale(1); opacity: 0.6; }
	25% { transform: translateY(-20rpx) scale(1.1); opacity: 0.8; }
	50% { transform: translateY(-10rpx) scale(0.95); opacity: 0.5; }
	75% { transform: translateY(-25rpx) scale(1.05); opacity: 0.7; }
}

@keyframes spin {
	from { transform: rotate(0deg); }
	to { transform: rotate(360deg); }
}

@keyframes errorPop {
	0% { opacity: 0; transform: translate(-50%, -50%) scale(0.8); }
	100% { opacity: 1; transform: translate(-50%, -50%) scale(1); }
}
</style>
