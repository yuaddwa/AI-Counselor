<template>
	<view class="page">
		<!-- 头部 -->
		<view class="login-header">
			<view class="header-status" :style="{ height: statusBarHeight + 'px' }"></view>
			<!-- 浮动装饰 -->
			<view class="float-bubble b1"></view>
			<view class="float-bubble b2"></view>
			<view class="float-bubble b3"></view>
			<view class="float-bubble b4"></view>
			<view class="float-bubble b5"></view>
			<view class="header-content">
				<view class="logo-wrap">
					<view class="logo-circle">
						<text class="logo-emoji">🤖</text>
					</view>
					<view class="logo-ring"></view>
					<view class="logo-ring ring2"></view>
				</view>
				<text class="app-title">AI辅导员</text>
				<text class="app-desc">您的校园智能助手</text>
			</view>
		</view>

		<!-- 波浪分隔 -->
		<view class="wave-separator">
			<view class="wave"></view>
		</view>

		<!-- 登录卡片 -->
		<view class="login-card">
			<!-- 身份切换 -->
			<view class="role-tabs">
				<view class="role-tab" :class="{ active: role === 'student' }" @click="switchRole('student')">
					<text class="tab-icon">👨‍🎓</text>
					<text>学生</text>
				</view>
				<view class="role-tab" :class="{ active: role === 'counselor' }" @click="switchRole('counselor')">
					<text class="tab-icon">👩‍🏫</text>
					<text>辅导员</text>
				</view>
				<view class="tab-slider" :style="{ left: role === 'student' ? '6rpx' : 'calc(50% + 6rpx)' }"></view>
			</view>

			<!-- 学生登录 -->
			<view class="login-form" v-if="role === 'student'" key="student">
				<view class="input-group" :class="{ focused: focusField === 'sid' }">
					<view class="input-icon">👤</view>
					<input class="login-input" v-model="studentForm.studentId" placeholder="请输入学号" type="text" @focus="focusField='sid'" @blur="focusField=''" />
				</view>
				<view class="input-group" :class="{ focused: focusField === 'spwd' }">
					<view class="input-icon">🔒</view>
					<input class="login-input" v-model="studentForm.password" placeholder="请输入密码" :password="!showPassword" @focus="focusField='spwd'" @blur="focusField=''" />
					<view class="input-eye" @click="showPassword = !showPassword">
						<text>{{ showPassword ? '👁' : '👁‍🗨' }}</text>
					</view>
				</view>
				<view class="login-btn" @click="handleStudentLogin" :class="{ loading: isLoading }">
					<text v-if="!isLoading">登 录</text>
					<view v-else class="btn-loading">
						<view class="spinner"></view>
						<text>登录中...</text>
					</view>
				</view>
				<view class="forgot-link" @click="handleForgot">
					<text>忘记密码？</text>
				</view>
			</view>

			<!-- 辅导员登录 -->
			<view class="login-form" v-if="role === 'counselor'" key="counselor">
				<view class="input-group" :class="{ focused: focusField === 'wid' }">
					<view class="input-icon">📋</view>
					<input class="login-input" v-model="counselorForm.workId" placeholder="请输入工号" type="text" @focus="focusField='wid'" @blur="focusField=''" />
				</view>
				<view class="input-group" :class="{ focused: focusField === 'cpwd' }">
					<view class="input-icon">🔒</view>
					<input class="login-input" v-model="counselorForm.password" placeholder="请输入密码" :password="!showPassword" @focus="focusField='cpwd'" @blur="focusField=''" />
					<view class="input-eye" @click="showPassword = !showPassword">
						<text>{{ showPassword ? '👁' : '👁‍🗨' }}</text>
					</view>
				</view>
				<view class="login-btn" @click="handleCounselorLogin" :class="{ loading: isLoading }">
					<text v-if="!isLoading">登 录</text>
					<view v-else class="btn-loading">
						<view class="spinner"></view>
						<text>登录中...</text>
					</view>
				</view>
			</view>

			<view class="card-footer">
				<text>登录即表示同意</text>
				<text class="link">《用户协议》</text>
				<text>和</text>
				<text class="link">《隐私政策》</text>
			</view>
		</view>

		<!-- 底部装饰 -->
		<view class="bottom-deco">
			<text class="deco-text">Campus AI Assistant</text>
		</view>

		<!-- 错误提示 -->
		<view class="error-toast" v-if="errorMsg">
			<text>{{ errorMsg }}</text>
		</view>
	</view>
</template>

<script>
import store from '@/common/store/index.js'

export default {
	data() {
		return {
			statusBarHeight: 0,
			role: 'student',
			showPassword: false,
			focusField: '',
			isLoading: false,
			errorMsg: '',
			studentForm: {
				studentId: '',
				password: ''
			},
			counselorForm: {
				workId: '',
				password: ''
			}
		}
	},
	created() {
		const windowInfo = uni.getWindowInfo()
		this.statusBarHeight = windowInfo.statusBarHeight || 0

		// 检查是否已登录
		if (store.state.isLogin) {
			this.redirectByRole(store.state.userType)
		}
	},
	methods: {
		switchRole(r) {
			if (this.role === r) return
			this.role = r
		},
		validateStudent() {
			if (!this.studentForm.studentId.trim()) {
				this.showError('请输入学号')
				return false
			}
			if (!this.studentForm.password.trim()) {
				this.showError('请输入密码')
				return false
			}
			return true
		},
		validateCounselor() {
			if (!this.counselorForm.workId.trim()) {
				this.showError('请输入工号')
				return false
			}
			if (!this.counselorForm.password.trim()) {
				this.showError('请输入密码')
				return false
			}
			return true
		},
		showError(msg) {
			this.errorMsg = msg
			setTimeout(() => { this.errorMsg = '' }, 3000)
		},
		handleStudentLogin() {
			if (!this.validateStudent()) return
			this.isLoading = true
			this.errorMsg = ''

			// 模拟登录
			setTimeout(() => {
				this.isLoading = false
				const userInfo = {
					id: this.studentForm.studentId,
					name: '张同学',
					className: '计算机2601',
					avatar: ''
				}
				store.mutations.setUserType('student')
				store.mutations.setToken('mock_token_student_' + Date.now())
				store.mutations.setUserInfo(userInfo)
				uni.setStorageSync('userInfo', userInfo)
				uni.setStorageSync('userType', 'student')

				uni.showToast({ title: '登录成功', icon: 'success' })
				setTimeout(() => {
					this.redirectByRole('student')
				}, 1000)
			}, 1500)
		},
		handleCounselorLogin() {
			if (!this.validateCounselor()) return
			this.isLoading = true
			this.errorMsg = ''

			setTimeout(() => {
				this.isLoading = false
				const userInfo = {
					id: this.counselorForm.workId,
					name: '李老师',
					role: '辅导员',
					avatar: ''
				}
				store.mutations.setUserType('counselor')
				store.mutations.setToken('mock_token_counselor_' + Date.now())
				store.mutations.setUserInfo(userInfo)
				uni.setStorageSync('userInfo', userInfo)
				uni.setStorageSync('userType', 'counselor')

				uni.showToast({ title: '登录成功', icon: 'success' })
				setTimeout(() => {
					this.redirectByRole('counselor')
				}, 1000)
			}, 1500)
		},
		handleForgot() {
			uni.showModal({
				title: '重置密码',
				content: '确认将密码重置为默认密码 123456？',
				success: (res) => {
					if (res.confirm) {
						this.studentForm.password = '123456'
						uni.showToast({ title: '已重置为默认密码', icon: 'success' })
					}
				}
			})
		},
		redirectByRole(role) {
			const url = role === 'student'
				? '/subpackages/student/pages/home/index'
				: '/subpackages/counselor/pages/workspace/index'
			uni.reLaunch({ url })
		}
	}
}
</script>

<style lang="scss" scoped>
.page {
	min-height: 100vh;
	background: linear-gradient(180deg, #E0F0FA 0%, #EAF4FD 20%, #F0F8FF 50%, #F5F6FA 100%);
	position: relative;
}

