	margin-bottom: 24rpx;
	position: relative;
}

.logo-circle {
	width: 120rpx;
	height: 120rpx;
	border-radius: 50%;
	background: rgba(255,255,255,0.6);
	backdrop-filter: blur(10rpx);
	display: flex;
	align-items: center;
	justify-content: center;
	border: 3rpx solid rgba(255,255,255,0.8);
	box-shadow: 0 8rpx 32rpx rgba(91,155,213,0.2);
	animation: logoPop 0.8s cubic-bezier(0.34,1.56,0.64,1) forwards, logoFloat 3s ease-in-out 1s infinite;
}

.logo-ring {
	position: absolute;
	top: -12rpx; left: -12rpx; right: -12rpx; bottom: -12rpx;
	border-radius: 50%;
	border: 2rpx dashed rgba(91,155,213,0.15);
	animation: ringRotate 12s linear infinite;
}

.ring2 {
	top: -24rpx; left: -24rpx; right: -24rpx; bottom: -24rpx;
	border-color: rgba(91,155,213,0.08);
	animation: ringRotate 18s linear infinite reverse;
}

