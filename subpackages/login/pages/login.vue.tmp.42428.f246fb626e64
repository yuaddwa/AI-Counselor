	padding-bottom: 80rpx;
	position: relative;
	overflow: hidden;
	background: linear-gradient(135deg, #D4EBFA 0%, #E0F0FA 40%, #EAF4FD 100%);
}

/* 浮动装饰气泡 */
.float-bubble {
	position: absolute;
	border-radius: 50%;
	z-index: 0;
}
