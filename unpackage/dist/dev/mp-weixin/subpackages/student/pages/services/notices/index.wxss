/* 自定义全局样式变量 */
/* uni-app 内置变量覆盖 */
.page.data-v-5a79b0fe {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #F5F6FA;
}
.notices-header.data-v-5a79b0fe {
  background: linear-gradient(135deg, #E8F4FD 0%, #F0F8FF 50%, #E8F4FD 100%);
  flex-shrink: 0;
}
.header-status.data-v-5a79b0fe {
  background: #E8F4FD;
}
.header-bar.data-v-5a79b0fe {
  height: 88rpx;
