  align-items: center;
  padding: 0 32rpx;
}
.header-back.data-v-5a79b0fe {
  width: 60rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  margin-right: 8rpx;
}
.header-back.data-v-5a79b0fe:active {
  transform: translateX(-6rpx);
}
.back-arrow.data-v-5a79b0fe {
  width: 20rpx;
  height: 20rpx;
  border-left: 3rpx solid #5B9BD5;
  border-bottom: 3rpx solid #5B9BD5;
  transform: rotate(45deg);
}
.arrow-right.data-v-5a79b0fe {
  width: 14rpx;
  height: 14rpx;
  border-right: 2rpx solid #999;
  border-bottom: 2rpx solid #999;
  transform: rotate(-45deg);
}
.header-title.data-v-5a79b0fe {
  font-size: 38rpx;
  color: #5B9BD5;
  font-weight: 600;
}
.scroll-content.data-v-5a79b0fe {
  flex: 1;
  height: 0;
}
.tab-content.data-v-5a79b0fe {
  padding: 24rpx;
}
.notice-item.data-v-5a79b0fe {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #FFF;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
  transition: transform 0.15s ease, box-shadow 0.2s ease;
}
.notice-item.data-v-5a79b0fe:active {
