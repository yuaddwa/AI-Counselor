}

/* 发布弹窗 */
.modal-mask.data-v-583a82c0 {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
}
.modal-wrap.data-v-583a82c0 {
  width: 100%;
  max-height: 85vh;
  background: #FFF;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx;
  overflow-y: auto;
  animation: slideUp-583a82c0 0.3s ease;
}
@keyframes slideUp-583a82c0 {
from {
    transform: translateY(100%);
}
to {
    transform: translateY(0);
}
}
.modal-title.data-v-583a82c0 {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 32rpx;
  text-align: center;
}
.form-group.data-v-583a82c0 {
  margin-bottom: 24rpx;
}
.form-label.data-v-583a82c0 {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 12rpx;
}
.form-radio-group.data-v-583a82c0 {
  display: flex;
  gap: 16rpx;
}
.form-radio.data-v-583a82c0 {
  padding: 12rpx 32rpx;
  background: #F5F6FA;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #666;
