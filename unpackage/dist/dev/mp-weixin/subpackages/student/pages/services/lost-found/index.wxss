/* 自定义全局样式变量 */
/* uni-app 内置变量覆盖 */
.page.data-v-583a82c0 {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #F5F6FA;
}
.page-header.data-v-583a82c0 {
  background: linear-gradient(135deg, #E8FFF3 0%, #F0FFF8 50%, #E8FFF3 100%);
  flex-shrink: 0;
  position: relative;
}
.header-status.data-v-583a82c0 {
  background: #E8FFF3;
}
.header-bar.data-v-583a82c0 {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
}
.header-back.data-v-583a82c0 {
  width: 60rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  transition: transform 0.2s ease;
}
.header-back.data-v-583a82c0:active {
  transform: translateX(-6rpx) scale(1.1);
}
.back-arrow.data-v-583a82c0 {
  width: 20rpx;
  height: 20rpx;
  border-left: 3rpx solid #1ABC9C;
  border-bottom: 3rpx solid #1ABC9C;
  transform: rotate(45deg);
}
.header-title.data-v-583a82c0 {
  font-size: 38rpx;
  color: #1ABC9C;
  font-weight: 600;
}
.header-publish.data-v-583a82c0 {
  padding: 10rpx 28rpx;
  background: #1ABC9C;
  border-radius: 28rpx;
  transition: transform 0.2s ease;
}
.header-publish.data-v-583a82c0:active {
  transform: scale(0.93);
}
.header-publish text.data-v-583a82c0 {
  font-size: 26rpx;
  color: #FFF;
  font-weight: 500;
}
.header-tabs.data-v-583a82c0 {
  display: flex;
  padding: 0 24rpx;
}
.header-tab.data-v-583a82c0 {
  flex: 1;
  text-align: center;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  color: rgba(26, 188, 156, 0.6);
  position: relative;
}
.header-tab.active.data-v-583a82c0 {
  color: #1ABC9C;
  font-weight: 500;
}
.tab-indicator.data-v-583a82c0 {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background: #1ABC9C;
  border-radius: 2rpx;
}
.scroll-content.data-v-583a82c0 {
  flex: 1;
  height: 0;
  padding-bottom: 40rpx;
}
.item-list.data-v-583a82c0 {
  padding: 24rpx;
}
.lost-card.data-v-583a82c0 {
  display: flex;
  background: #FFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
