}
.meta-icon.data-v-583a82c0 {
  font-size: 22rpx;
  color: #CCC;
}
.lost-image.data-v-583a82c0 {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  overflow: hidden;
  flex-shrink: 0;
}
.lost-image image.data-v-583a82c0 {
  width: 100%;
  height: 100%;
}
.empty-hint.data-v-583a82c0 {
  text-align: center;
  padding: 80rpx 0;
}
.empty-hint text.data-v-583a82c0 {
  font-size: 26rpx;
  color: #CCC;
}
.loading-more.data-v-583a82c0 {
  text-align: center;
  padding: 24rpx;
}
.loading-more text.data-v-583a82c0 {
  font-size: 24rpx;
  color: #999;
}
.bottom-space.data-v-583a82c0 {
