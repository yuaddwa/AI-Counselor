  padding: 0 20rpx;
  font-size: 26rpx;
}
.form-textarea.data-v-583a82c0 {
  width: 100%;
  height: 160rpx;
  background: #F5F6FA;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 26rpx;
