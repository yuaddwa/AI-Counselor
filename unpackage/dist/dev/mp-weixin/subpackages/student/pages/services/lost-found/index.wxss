  position: relative;
  transition: transform 0.15s ease;
}
.lost-card.data-v-583a82c0:active {
  transform: scale(0.98);
}
.lost-type-tag.data-v-583a82c0 {
  position: absolute;
  top: 0;
  right: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 0 0 8rpx 8rpx;
}
.lost-type-tag text.data-v-583a82c0 {
  font-size: 22rpx;
  color: #1ABC9C;
  font-weight: 500;
}
.lost-body.data-v-583a82c0 {
  flex: 1;
  margin-right: 20rpx;
}
.lost-title.data-v-583a82c0 {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  display: block;
  margin-bottom: 8rpx;
}
.lost-desc.data-v-583a82c0 {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
.lost-meta.data-v-583a82c0 {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.meta-item.data-v-583a82c0 {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 22rpx;
