}
.upload-area.data-v-583a82c0 {
  width: 160rpx;
  height: 160rpx;
  background: #F5F6FA;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #DDD;
}
.upload-preview.data-v-583a82c0 {
