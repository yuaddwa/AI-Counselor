/* 自定义全局样式变量 */
/* uni-app 内置变量覆盖 */
.page.data-v-3a0afccf {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #F5F6FA;
}
.orders-header.data-v-3a0afccf {
  background: linear-gradient(135deg, #4A90D9 0%, #6BA5E7 50%, #4A90D9 100%);
  background-size: 200% 200%;
}
.header-status.data-v-3a0afccf {
  background: #4A90D9;
}
.header-bar.data-v-3a0afccf {
  height: 88rpx;
  display: flex;
  align-items: center;
  padding: 0 32rpx;
}
.header-title.data-v-3a0afccf {
  font-size: 38rpx;
  color: #FFF;
  font-weight: 600;
}
.filter-tabs.data-v-3a0afccf {
  display: flex;
  padding: 0 24rpx 16rpx;
}
.filter-tab.data-v-3a0afccf {
  flex: 1;
  text-align: center;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  border-radius: 8rpx;
  transition: all 0.3s ease;
}
.filter-tab.active.data-v-3a0afccf {
  background: rgba(255, 255, 255, 0.2);
  color: #FFF;
}
.scroll-content.data-v-3a0afccf {
  flex: 1;
  height: 0;
  padding-bottom: 140rpx;
}
.filter-bar.data-v-3a0afccf {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  gap: 12rpx;
}
.filter-item.data-v-3a0afccf {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 20rpx;
  background: #FFF;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #666;
  min-width: 160rpx;
  transition: transform 0.15s ease;
}
.filter-item.data-v-3a0afccf:active {
  transform: scale(0.96);
}
.filter-arrow-down.data-v-3a0afccf {
  width: 16rpx;
  height: 16rpx;
  border-right: 2rpx solid rgba(255, 255, 255, 0.7);
  border-bottom: 2rpx solid rgba(255, 255, 255, 0.7);
  transform: rotate(45deg);
  transition: transform 0.3s ease;
}
.filter-arrow.data-v-3a0afccf {
  color: #CCC;
  font-size: 28rpx;
  transform: rotate(-90deg);
}
.filter-search.data-v-3a0afccf {
  flex: 1;
  height: 64rpx;
  background: #FFF;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 24rpx;
}
.order-list.data-v-3a0afccf {
  padding: 0 24rpx;
}
.archive-bar.data-v-3a0afccf {
  text-align: center;
  padding: 24rpx;
  font-size: 26rpx;
  color: #4A90D9;
  transition: color 0.2s ease;
}
.archive-bar.data-v-3a0afccf:active {
  color: #3A7CC5;
}
.bottom-space.data-v-3a0afccf {
  height: 40rpx;
}