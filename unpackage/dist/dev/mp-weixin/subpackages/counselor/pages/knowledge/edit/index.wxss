.page.data-v-97170c64 {
  height: 100vh;
  background: #F5F6FA;
}
.edit-scroll.data-v-97170c64 {
  height: 100%;
  padding: 24rpx;
}
.form-group.data-v-97170c64 {
  background: #FFF;
