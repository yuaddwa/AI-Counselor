/* 自定义全局样式变量 */
/* uni-app 内置变量覆盖 */
.page.data-v-c9b1cc8b {
  height: 100vh;
  background: #F5F6FA;
}
.create-scroll.data-v-c9b1cc8b {
  height: 100%;
  padding: 24rpx;
}
.form-group.data-v-c9b1cc8b {
  background: #FFF;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}
.form-label.data-v-c9b1cc8b {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  display: block;
  margin-bottom: 16rpx;
}
.form-input.data-v-c9b1cc8b {
  height: 72rpx;
  background: #F5F6FA;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
}
.form-textarea.data-v-c9b1cc8b {
  width: 100%;
  min-height: 400rpx;
  background: #F5F6FA;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  line-height: 1.6;
  box-sizing: border-box;
}
.scope-options.data-v-c9b1cc8b {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}
.scope-option.data-v-c9b1cc8b {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F5F6FA;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #666;
}
.scope-option.active.data-v-c9b1cc8b {
  background: #4A90D9;
  color: #FFF;
}
.class-select.data-v-c9b1cc8b {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}
.class-option.data-v-c9b1cc8b {
  padding: 12rpx 24rpx;
  background: #F5F6FA;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #666;
}
.class-option.selected.data-v-c9b1cc8b {
  background: #4A90D9;
  color: #FFF;
}
.form-actions.data-v-c9b1cc8b {
  display: flex;
  gap: 20rpx;
  padding: 32rpx 0;
}
.btn-draft.data-v-c9b1cc8b, .btn-publish.data-v-c9b1cc8b {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  font-size: 30rpx;
}
.btn-draft.data-v-c9b1cc8b {
  background: #FFF;
  color: #4A90D9;
  border: 1rpx solid #4A90D9;
}
.btn-publish.data-v-c9b1cc8b {
  background: #4A90D9;
  color: #FFF;
}