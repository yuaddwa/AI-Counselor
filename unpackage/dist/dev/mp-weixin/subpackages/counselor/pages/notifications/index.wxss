/* 自定义全局样式变量 */
/* uni-app 内置变量覆盖 */
.page.data-v-c930e4fd {
  height: 100vh;
  background: #F5F6FA;
}
.scroll-content.data-v-c930e4fd {
  height: 100%;
  padding: 24rpx;
}
.action-header.data-v-c930e4fd {
  margin-bottom: 16rpx;
}
.create-btn.data-v-c930e4fd {
  padding: 16rpx 32rpx;
  background: linear-gradient(135deg, #4A90D9, #6BA5E7);
  border-radius: 12rpx;
  text-align: center;
  color: #FFF;
  font-size: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(74, 144, 217, 0.3);
  transition: transform 0.15s ease, box-shadow 0.2s ease;
}
.create-btn.data-v-c930e4fd:active {
  transform: scale(0.96);
  box-shadow: 0 2rpx 8rpx rgba(74, 144, 217, 0.2);
}
.notice-list.data-v-c930e4fd {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.notice-item.data-v-c930e4fd {
  background: #FFF;
  border-radius: 12rpx;
  padding: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
  transition: transform 0.15s ease, box-shadow 0.2s ease;
}
.notice-item.data-v-c930e4fd:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(74, 144, 217, 0.12);
}
.notice-main.data-v-c930e4fd {
  flex: 1;
  margin-right: 16rpx;
}
.notice-title.data-v-c930e4fd {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  display: block;
